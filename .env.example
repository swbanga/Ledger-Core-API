# ==============================================================================
# LEDGER-CORE: LOCAL DEPLOYMENT ENVIRONMENT BLUEPRINT
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to .env
# 2. Replace the placeholder values with highly secure cryptographic strings.
# 3. DO NOT commit the actual .env file to version control.
# ==============================================================================

# ---------------------------------------------------------
# DATABASE CONFIGURATION (Azure SQL Edge)
# ---------------------------------------------------------
# Must meet strict SQL Server password complexity requirements
DB_PASSWORD=YourTitaniumSecurePassword123!

# ---------------------------------------------------------
# CACHE CONFIGURATION (Redis)
# ---------------------------------------------------------
# Distributed lock and idempotency cache authentication
REDIS_PASSWORD=YourSecureCachePassword123!

# ---------------------------------------------------------
# CRYPTOGRAPHY & IDENTITY (JWT)
# ---------------------------------------------------------
# Secret must be at least 32 characters long
JWT_SECRET=YourSuperSecureEnterpriseJwtSecretKey2026!
JWT_ISSUER=LedgerCore.Identity
JWT_AUDIENCE=LedgerCore.Network
