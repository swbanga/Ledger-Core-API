using System;
using System.Linq;
using System.Reflection;
using LedgerCore.Application.Features.Accounts.Commands.CreateAccount;
using LedgerCore.Infrastructure.Database;
using MediatR;
using NetArchTest.Rules;
using Xunit;

namespace LedgerCore.ArchitectureTests;

public class ApplicationArchitectureTests
{
    private static readonly Assembly ApplicationAssembly = typeof(CreateAccountCommand).Assembly;
    private static readonly string ApplicationRoot =
        string.Join('.', (typeof(CreateAccountCommand).Namespace ?? string.Empty).Split('.').Take(2));
    private static readonly string InfrastructureRoot =
        string.Join('.', (typeof(LedgerDbContext).Namespace ?? string.Empty).Split('.').Take(2));
    private static readonly string ApiRoot =
        typeof(LedgerCore.Api.Program).Namespace!;

    [Fact]
    public void Application_should_not_depend_on_Infrastructure()
    {
        var result = Types.InAssembly(ApplicationAssembly)
            .That().ResideInNamespace(ApplicationRoot)
            .ShouldNot()
            .HaveDependencyOn(InfrastructureRoot)
            .GetResult();

        Assert.True(result.IsSuccessful,
            $"Application types have a dependency on the Infrastructure layer: {string.Join(", ", result.FailingTypeNames ?? Array.Empty<string>())}");
    }

    [Fact]
    public void Application_should_not_depend_on_Api()
    {
        var result = Types.InAssembly(ApplicationAssembly)
            .That().ResideInNamespace(ApplicationRoot)
            .ShouldNot()
            .HaveDependencyOn(ApiRoot)
            .GetResult();

        Assert.True(result.IsSuccessful,
            $"Application types have a dependency on the Api layer: {string.Join(", ", result.FailingTypeNames ?? Array.Empty<string>())}");
    }

    [Fact]
    public void All_MediatR_handlers_end_with_CommandHandler_or_QueryHandler()
    {
        var handlerInterface = typeof(IRequestHandler<,>);

        var result = Types.InAssembly(ApplicationAssembly)
            .That()
            .ImplementInterface(handlerInterface)
            .Should()
            .MeetCustomRule(t =>
                t.Name.EndsWith("CommandHandler") || t.Name.EndsWith("QueryHandler"))
            .GetResult();

        Assert.True(result.IsSuccessful,
            $"Handlers must end with 'CommandHandler' or 'QueryHandler': {string.Join(", ", result.FailingTypeNames ?? Array.Empty<string>())}");
    }

    [Fact]
    public void MediatR_handlers_are_internal_or_sealed()
    {
        var handlerInterface = typeof(IRequestHandler<,>);

        var result = Types.InAssembly(ApplicationAssembly)
            .That()
            .ImplementInterface(handlerInterface)
            .Should()
            .MeetCustomRule(t =>
                t.IsSealed || (t.IsClass && !t.IsVisible))
            .GetResult();

        Assert.True(result.IsSuccessful,
            $"Handlers must be internal or sealed: {string.Join(", ", result.FailingTypeNames ?? Array.Empty<string>())}");
    }
}
